<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tv_live_clock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2026-06-13 14:00:00"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1976D2"
        android:gravity="center"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tv_admin_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="원장 가입 승인 대시보드"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="15dp"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_analysis"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="실시간 하원 트래픽 분석 (터치 시 그래프 보기)"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="16sp"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tv_total_logs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="분석 데이터: 계산 중..."
                android:textSize="14sp"
                android:textColor="#555555"/>

            <TextView
                android:id="@+id/tv_avg_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="평균 소요 시간: 계산 중..."
                android:textSize="14sp"
                android:textColor="#555555"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tv_peak_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="병목 예상 구간: 계산 중..."
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#E65100"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layout_chart_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="15dp"
        android:layout_marginBottom="15dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="15dp">
            <Button android:id="@+id/btn_filter_day" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="하루(오늘)" style="?android:attr/buttonBarButtonStyle" android:textSize="12sp"/>
            <Button android:id="@+id/btn_filter_week" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="주간 분석" style="?android:attr/buttonBarButtonStyle" android:textSize="12sp"/>
            <Button android:id="@+id/btn_filter_month" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="월간 분석" style="?android:attr/buttonBarButtonStyle" android:textSize="12sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:weightSum="6"
            android:layout_marginBottom="5dp">
            <View android:id="@+id/bar_slot1" android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#03A9F4"/>
            <View android:id="@+id/bar_slot2" android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#03A9F4"/>
            <View android:id="@+id/bar_slot3" android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#E65100"/>
            <View android:id="@+id/bar_slot4" android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#E65100"/>
            <View android:id="@+id/bar_slot5" android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#03A9F4"/>
            <View android:id="@+id/bar_slot6" android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" android:layout_margin="4dp" android:background="#03A9F4"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="6">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="16:00" android:textSize="10sp" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="16:20" android:textSize="10sp" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="16:40" android:textSize="10sp" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="17:00" android:textSize="10sp" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="17:20" android:textSize="10sp" android:gravity="center"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="17:40" android:textSize="10sp" android:gravity="center"/>
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btn_daily_reset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="하루 시작 (등하원 데이터 일괄 초기화)"
        android:backgroundTint="#03A9F4"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="15dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👤 가입 승인 대기열"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_admin"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>